# ============================================
# Star Academy Backend - Environment Variables
# ============================================
# Copy this file as .env and fill in your values.
# NEVER commit this file to version control.
# ============================================

# --- MongoDB ---
MONGODB_URI=

# --- Server ---
PORT=8080

# --- AWS S3 ---
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# --- JWT ---
JWT_SECRET=

# --- Admin Credentials ---
ADMIN_USERNAME=
ADMIN_PASSWORD=
